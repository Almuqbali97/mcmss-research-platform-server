# Server
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/medical-research-platform
DB_NAME=medical-research-platform

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Email (Nodemailer - SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@medical-research-platform.com

# Frontend & App (CORS — must match your live site origin exactly, no trailing slash)
FRONTEND_URL=http://localhost:5173

# Production example:
# FRONTEND_URL=https://researchportal.app
APP_NAME=Research and Studies Committee
# Optional: Full URL for logo in emails (default: https://mcmss-client.onrender.com/assets/logo-DVgwY-qi.png)
# EMAIL_LOGO_URL=https://example.com/custom-logo.png

# OTP
OTP_EXPIRES_IN_MINUTES=15
OTP_LENGTH=6
